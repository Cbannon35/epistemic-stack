# Copy to .env and fill in. Local values for the Supabase keys are printed by `supabase start`.

# --- Supabase (auth + realtime + db) -----------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=****        # `supabase start` → anon key
SUPABASE_SECRET_KEY=****                  # `supabase start` → service_role key

# --- Postgres (the commons) ---------------------------------------------------
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres

# --- eve durable sessions (@workflow/world-postgres) --------------------------
# Same local Postgres is fine.
WORKFLOW_POSTGRES_URL=postgres://postgres:postgres@127.0.0.1:54422/postgres
WORKFLOW_TARGET_WORLD=@workflow/world-postgres
WORKFLOW_QUEUE_NAMESPACE=eve

# --- Models -------------------------------------------------------------------
# Powers eve + tours + delegated investigations. (lib/eve-model.ts falls back to
# OPENAI_API_KEY if unset.)
ANTHROPIC_API_KEY=****

# --- Web search (recommended) ---------------------------------------------------
# eve's search_web tool + delegated investigations' research phase. Without it,
# delegated runs can't add sourced claims (structure-only fallback).
TAVILY_API_KEY=****
